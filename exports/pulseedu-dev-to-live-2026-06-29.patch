+// Map a redemption-engine failure code to an HTTP status.
+function redeemErrorStatus(code: string): number {
+  switch (code) {
+    case "not_found":
+      return 404;
+    case "insufficient_points":
+    case "out_of_stock":
+    case "limit_reached":
+    case "archived":
+    case "invalid_state":
+      return 409;
+    default:
+      return 400;
+  }
