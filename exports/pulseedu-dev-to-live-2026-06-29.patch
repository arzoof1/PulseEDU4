+              <strong>{getPrimary(item)}</strong>
+              {renderMeta ? (
+                <span style={{ color: "#64748b" }}> {renderMeta(item)}</span>
+              ) : null}
+            </li>
+          ))}
+        </ul>
+      )}
+      {showEmpty && <div style={noticeStyle}>{emptyText}</div>}
+    </div>
+  );
+}
