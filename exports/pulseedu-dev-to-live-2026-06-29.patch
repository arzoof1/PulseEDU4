+      };
+      const pad = 4;
+      const colX = (i: number) =>
+        tableX + cols.slice(0, i).reduce((a, c) => a + c.w, 0);
+
+      const drawHeaderRow = () => {
+        const h = 18;
+        const y0 = doc.y;
+        doc.save();
+        doc.rect(tableX, y0, tableW, h).fill("#0f172a");
+        doc.restore();
+        doc.font("Helvetica-Bold").fontSize(9).fillColor("#ffffff");
+        cols.forEach((c, i) => {
+          doc.text(c.label, colX(i) + pad, y0 + 5, {
+            width: c.w - pad * 2,
+            lineBreak: false,
