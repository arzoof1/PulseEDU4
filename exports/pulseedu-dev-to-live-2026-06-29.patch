+    const byLocal = new Map(students.map((s) => [s.localSisId, s.studentId]));
+    let matched = 0;
+    const unmatched: string[] = [];
+    for (const r of rows) {
+      const local = String(r.localSisId ?? "").trim();
+      const resolved = local ? byLocal.get(local) : undefined;
+      if (!resolved) {
+        if (local) unmatched.push(local);
+        continue;
