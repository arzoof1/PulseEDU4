+      `/api/interventions/effectiveness?studentId=${encodeURIComponent(
+        studentId,
+      )}&behaviorReason=${encodeURIComponent(selectedBehavior.name)}`,
+    )
+      .then((r) => (r.ok ? r.json() : null))
+      .then((j: { byType?: EffByType } | null) => {
+        if (!cancelled && j) setEff(j.byType ?? {});
