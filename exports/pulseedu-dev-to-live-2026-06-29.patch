+            setOpen(true);
+            return;
+          }
+          if (e.key === "ArrowDown") {
+            e.preventDefault();
+            setHighlight((h) => Math.min(h + 1, matches.length - 1));
+          } else if (e.key === "ArrowUp") {
+            e.preventDefault();
+            setHighlight((h) => Math.max(h - 1, 0));
+          } else if (e.key === "Enter") {
+            if (open && matches[highlight]) {
+              e.preventDefault();
+              commit(matches[highlight]);
+            }
+          } else if (e.key === "Escape") {
+            setOpen(false);
+          }
+        }}
