# Production template for https://pulseedu.pulsekinetics.us/
# Copy to `.env` on the server (e.g. /var/www/PulseEDU4/artifacts/api-server/.env)

NODE_ENV=production
PORT=8080

PUBLIC_APP_URL=https://pulseedu.pulsekinetics.us
CORS_ORIGINS=https://pulseedu.pulsekinetics.us

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/pulseedu
SESSION_SECRET=generate-a-long-random-secret

RUN_BOOT_SEED=false
EMAIL_REMINDERS_ENABLED=false
STAFF_BEARER_AUTH_ENABLED=false

# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# File uploads (School Tours, Class Photo Day, store images, etc.)
# When set, the API uses S3 presigned PUT/GET instead of Replit/GCS sidecar.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name
# Optional prefixes inside the bucket (defaults shown):
# S3_PRIVATE_PREFIX=private
# S3_PUBLIC_PREFIX=public
#
# S3 bucket CORS must allow PUT/GET from https://pulseedu.pulsekinetics.us
#
# Replit/GCS fallback (only if AWS vars above are unset):
# PUBLIC_OBJECT_SEARCH_PATHS=/bucket/public
# PRIVATE_OBJECT_DIR=/bucket/.private
