# Production template for https://pulseedu.pulsekinetics.us/
# Copy to `.env` on the server (e.g. /var/www/PulseEDU4/artifacts/api-server/.env)

NODE_ENV=production
PORT=8080

PUBLIC_APP_URL=https://pulseedu.pulsekinetics.us
CORS_ORIGINS=https://pulseedu.pulsekinetics.us

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/pulseedu
SESSION_SECRET=generate-a-long-random-secret

# Apply schema migrations on boot. With Adminer removed, production must set
# this to TRUE so the app runs its idempotent schema ensures at startup.
# Base tables still come from `drizzle-kit push` (run once via SSH on a brand-
# new database); this flag drives the incremental column/table top-ups.
RUN_BOOT_SEED=true
# Seed DEMO data (demo students / schools / scores). MUST stay false/unset in
# production — with it off, RUN_BOOT_SEED=true migrates schema ONLY. Set true
# only for a throwaway demo environment.
# SEED_DEMO_DATA=false
EMAIL_REMINDERS_ENABLED=false
STAFF_BEARER_AUTH_ENABLED=false

# Staff MFA. Master switch (default on) — set false to disable all MFA
# endpoints + enforcement instantly. Enforcement is still per-school/district
# policy, so "on" alone forces no one. MFA_ENC_KEY is a DEDICATED 32+ char
# random secret used to encrypt staff TOTP seeds at rest (kept separate from
# SESSION_SECRET per the security review). REQUIRED before any staff enrolls.
# STAFF_MFA_ENABLED=true
# MFA_ENC_KEY=generate-a-long-random-secret-distinct-from-session-secret

# Global AI kill switch — set to false to disable all AI surfaces at deploy time.
# AI_FEATURES_ENABLED=true

# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# SMS (Twilio) — parent/staff text alerts. Inert until SMS_ENABLED=true AND a
# sender is set. Authenticate with an API Key (SID + Secret), not the Auth Token.
# SMS_ENABLED=false
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_API_KEY_SID=SK...
# TWILIO_API_KEY_SECRET=...
# Provide ONE sender (Messaging Service preferred):
# TWILIO_MESSAGING_SERVICE_SID=MG...
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# File uploads (School Tours, Class Photo Day, store images, etc.)
# When set, the API uses S3 presigned PUT/GET instead of Replit/GCS sidecar.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name
# Optional prefixes inside the bucket (defaults shown):
# S3_PRIVATE_PREFIX=private
# S3_PUBLIC_PREFIX=public
#
# S3 bucket CORS must allow PUT/GET from https://pulseedu.pulsekinetics.us
#
# Replit/GCS fallback (only if AWS vars above are unset):
# PUBLIC_OBJECT_SEARCH_PATHS=/bucket/public
# PRIVATE_OBJECT_DIR=/bucket/.private
