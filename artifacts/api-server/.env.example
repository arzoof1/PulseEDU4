# Copy to `.env` for local development, or set these in production secrets (PM2, etc.).
#
# Production site: https://pulseedu.pulsekinetics.us/

# --- Required ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/pulseedu
SESSION_SECRET=generate-a-long-random-secret
PORT=8080

# --- Production (https://pulseedu.pulsekinetics.us/) ---
# NODE_ENV=production
# PUBLIC_APP_URL=https://pulseedu.pulsekinetics.us
# CORS_ORIGINS=https://pulseedu.pulsekinetics.us
# RUN_BOOT_SEED=false

# --- Local development ---
# `pnpm run dev` loads `.env` then `.env.development` (committed) for CORS/cookies.
# Copy this file to `.env` and set DATABASE_URL + SESSION_SECRET at minimum.
#
# The production RDS IP (172.31.x.x) is not reachable from your laptop directly.
# Use an SSH tunnel through EC2, then point DATABASE_URL at 127.0.0.1:5432.

EMAIL_REMINDERS_ENABLED=false
STAFF_BEARER_AUTH_ENABLED=false

# Optional: one-time full demo seed on empty DB
# RUN_BOOT_SEED=true

# Email (production)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=PulseEDU <noreply@pulsekinetics.us>

# Object storage (production uploads)
# PUBLIC_OBJECT_SEARCH_PATHS=/bucket/public
# PRIVATE_OBJECT_DIR=/bucket/.private
