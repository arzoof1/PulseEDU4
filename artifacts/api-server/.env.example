# Copy to `.env` for local development, or set these in production secrets (PM2, etc.).
#
# Production site: https://pulseedu.pulsekinetics.us/

# --- Required ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/pulseedu
SESSION_SECRET=generate-a-long-random-secret
PORT=8080

# --- Production (https://pulseedu.pulsekinetics.us/) ---
# NODE_ENV=production
# PUBLIC_APP_URL=https://pulseedu.pulsekinetics.us
# CORS_ORIGINS=https://pulseedu.pulsekinetics.us
# RUN_BOOT_SEED=false

# --- Local development ---
# `pnpm run dev` loads `.env` then `.env.development` (committed) for CORS/cookies.
# Copy this file to `.env` and set DATABASE_URL + SESSION_SECRET at minimum.
#
# The production RDS IP (172.31.x.x) is not reachable from your laptop directly.
# Use an SSH tunnel through EC2, then point DATABASE_URL at 127.0.0.1:5432.

EMAIL_REMINDERS_ENABLED=false
STAFF_BEARER_AUTH_ENABLED=false

# Global AI kill switch. When false, all AI surfaces are disabled server-side
# (Help Assistant, PulseDNA, watchlist consistency, mention suggest, tour
# translation) regardless of per-school licensing. Default: enabled.
# AI_FEATURES_ENABLED=true

# Staff MFA. STAFF_MFA_ENABLED (default on) is the master kill switch.
# MFA_ENC_KEY is a dedicated secret for encrypting staff TOTP seeds at rest
# (separate from SESSION_SECRET). If unset in dev, a SESSION_SECRET-derived
# fallback key is used (a warning is logged); production MUST set it.
# STAFF_MFA_ENABLED=true
# MFA_ENC_KEY=

# ClassLink / OneRoster — use on-disk fixtures instead of live API (dev only)
# CLASSLINK_MOCK=true
# CLASSLINK_ONEROSTER_BASE_URL=
# CLASSLINK_ONEROSTER_CLIENT_ID=
# CLASSLINK_ONEROSTER_CLIENT_SECRET=

# Scheduled jobs (digest, weekly heartbeat, nightly ClassLink roster sync)
# RUN_SCHEDULED_JOBS=true
# SIS_ROSTER_SYNC_CRON=0 2 * * *
# SIS_ROSTER_SYNC_TZ=America/New_York
# SIS_ROSTER_SYNC_ENABLED=true

# Optional: one-time full demo seed on empty DB
# RUN_BOOT_SEED=true

# Email (production)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=PulseEDU <noreply@pulsekinetics.us>

# SMS (Twilio) — parent/staff text alerts. Inert until SMS_ENABLED=true AND a
# sender (Messaging Service or number) is set. Authenticate with an API Key
# (SID + Secret), NOT the account Auth Token.
# SMS_ENABLED=false
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_API_KEY_SID=SK...
# TWILIO_API_KEY_SECRET=...
# Provide ONE sender (Messaging Service preferred — handles opt-out + pooling):
# TWILIO_MESSAGING_SERVICE_SID=MG...
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Object storage (production uploads)
# PUBLIC_OBJECT_SEARCH_PATHS=/bucket/public
# PRIVATE_OBJECT_DIR=/bucket/.private
